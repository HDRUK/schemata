{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://hdruk.github.io/schemata/schema/paper/draft/paper.schema.json",
    "title": "HDR UK Paper Schema",
    "description": "HDR UK Paper Metadata JSONSchema",
    "type": "object",
    "version": "0.0.1",
    "required": [
        "identifier",
        "title",
        "links",
        "journal",
        "abstract",
        "resultsInsights",
        "uploaders"
    ],
    "additionalProperties": false,
    "properties": {
        "identifier": {
            "$id": "#/properties/identifier",
            "title": "Paper Identifier",
            "description": "System paper identifier",
            "examples": [],
            "oneOf": [
                {
                    "type": "string",
                    "format":"uuid"
                },
                {
                    "type": "string",
                    "format": "uri"
                }
            ]
        },
        "title": {
            "$id": "#/properties/title",
            "title": "Paper Title",
            "description": "Title of the paper limited to 80 characters. It should be unique across the Gateway. Please avoid acronyms wherever possible.",
            "examples": ["Efficacy of contact tracing for the containment of the 2019 novel coronavirus (COVID-19)."],
            "type": "string",
            "minLength": 2,
            "maxLength": 80
        },
        "links": {
            "$id": "#/properties/doiandOtherLinks",
            "title": "Paper Links",
            "description": "DOI or URL endpoint to where can we find this tool or resource",
            "examples": [
                ["https://github.com/OHDSI/WhiteRabbit"]
            ],
            "type": "array",
            "minItems": 1,
            "items": {
                "$anyOf": [
                    {
                        "title": "DOI",
                        "type": "string",
                        "pattern": "^(10\\.\\d{4,9}/[-._;()/:A-Z0-9]+[^.])$"
                    },
                    {
                        "type": "Other URL",
                        "format": "uri"
                    }
                ]
            }
        },
        "authors": {
            "$id": "#/properties/authors",
            "title": "Authors",
            "description": "A list of authors of the paper.", 
            "examples": [
                ["Shahriar Kabir Khan", "Ned Stark", "John Snow"],
                ["Joe Bloggs", "Jane Doe"]
            ],
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
            },
            "uniqueItems": true
        },
        "journal": {
            "$id": "#/properties/journal",
            "title": "Journal",
            "description": "Information about the journal the paper was published in - title and year.",
            "examples": [
                {
                    "title": "Journal of epidemiology and community health",
                    "year": "2020"
                }
            ],
            "type": "object",
            "properties": {
                "title": {
                    "$id": "#/properties/journal/properties/title",
                    "title": "Journal Title",
                    "description": "The title of the journal.",
                    "examples": ["Journal of epidemiology and community health"],
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 80
                },
                "year": {
                    "$id": "#/properties/journal/properties/year",
                    "title": "Journal Year",
                    "description": "The year the journal was published.",
                    "examples": ["2020"],
                    "type": "string",
                    "pattern": "^\\d{4}$"
                } 
            },
        },
        "abstract": {
            "$id": "#/properties/abstract",
            "title": "Paper Abstract",
            "description": "Please provide a brief summary of the paper.",
            "examples": ["WhiteRabbit is a small application that can be used to analyze the structure and contents of a database as preparation for designing an ETL. It comes with RabbitInAHat, an application for interactive design of an ETL to the OMOP Common Data Model with the help of the scan report generated by White Rabbit."],
            "type": "string",
            "minLength": 2,
            "maxLength": 3000
        },
        "resultsInsights": {
            "$id": "#/properties/resultsInsights",
            "title": "Paper Results/Insights",
            "examples": ["The main goal for CogStack is to provide a generalised way to access the various modes of unstructured data in a clinical record, harmonise them into a common format and index them in Elasticsearch for information retrieval. Ontop Elasticsearch is an NLP pipeline (CogStack MedCat) for information extraction."],
            "description": "Please provide any results or insights about the paper.",
            "type": "string",
            "minLength": 2,
            "maxLength": 3000
        },
        "keywords": {
            "$id": "#/properties/keywords",
            "title": "Paper Keywords",
            "examples": [["Data Profiling","Analysis","Statistics"]],
            "description": "",
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
            },
            "uniqueItems": true
        },
        "uploaders": {
            "$id": "#/properties/uploaders",
            "title": "Uploaders to Innovation Gateway",
            "examples": [
                [
                    "https://web.www.healthdatagateway.org/person/5050276793730464", 
                    "https://web.www.healthdatagateway.org/person/18192243612685188"
                ]
            ],
            "description": "Links to the profiles of the uploader(s) of the paper to the Innovation Gateway.",
            "type": "array",
            "items": {
                "type": "string",
                "pattern": "^(https://web.www.healthdatagateway.org/person/\\d+)$"
            },
            "uniqueItems": true
        },
        "domain": {
            "$id": "#/properties/domain",
            "title": "Paper Domain",
            "description": "",
            "examples": [["COVID-19", "Clinical Trial","Respiratory"]],
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
            },
            "uniqueItems": true
        },
        "relatedResources": {
            "$id": "#/properties/relatedResources",
            "title": "Related Resources",
            "description": "Show relationships to papers, data uses, datasets and tools. Resources must be added to the Gateway first.",
            "examples": ["The relationships to papers, projects, datasets and tools."],
            "type": "array",
            "items": {"$ref": "#/definitions/relatedResource"},
            "uniqueItems": true
        }
    },
    "definitions": {
        "relatedResource": {
            "title": "Paper Related Resource",
            "$id": "#/definitions/relatedResource",
            "type": "object",
            "properties": {
                "resource": {
                    "$id": "#/definitions/relatedResource/resource",
                    "title": "Paper Related Resource",
                    "description": "The identifier of the related resource.",
                    "examples": ["https://web.www.healthdatagateway.org/dataset/f93aea28-7592-42c0-a5e7-5802f0d6051f"],
                    "type": "string",
                    "format": "uri"
                },
                "relationship": {
                    "$id": "#/definitions/relatedResource/relationship",
                    "title": "Paper Relationship Between Resources",
                    "description": "What is the relationship between these resources?",
                    "examples": ["Covid-19 questionnaire data will be available in this dataset"],
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 3000
                }
            }
        }
    }
}
