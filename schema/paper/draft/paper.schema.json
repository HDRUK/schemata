{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://hdruk.github.io/schemata/schema/paper/draft/paper.schema.json",
    "title": "HDR UK Paper Schema",
    "description": "HDR UK Paper Metadata JSONSchema",
    "type": "object",
    "version": "0.0.1",
    "required": [
        "identifier",
        "title",
        "doiandOtherLinks",
        "authorsOntheGateway",
        "journal",
        "abstract",
        "resultsInsights"
    ],
    "additionalProperties": false,
    "properties": {
        "identifier": {
            "$id": "#/properties/identifier",
            "title": "Paper Identifier",
            "$comment": "",
            "description": "System paper identifier",
            "examples": [],
            "anyOf": [
                {
                    "type": "string",
                    "format":"uuid"
                },
                {
                    "type": "string",
                    "format": "uri"
                }
            ]
        },
        "title": {
            "$id": "#/properties/title",
            "title": "Paper Title",
            "$comment": "",
            "description": "Title of the paper limited to 80 characters. It should be unique across the Gateway. Please avoid acronyms wherever possible.",
            "examples": [
                "WhiteRabbit"
            ],
            
            "type": "string",
            "minLength": 2,
            "maxLength": 80
                
            
        },
        "doiandOtherLinks": {
            "$id": "#/properties/doiandOtherLinks",
            "title": "Paper Links",
            "$comment": "",
            "examples": [
                [
                "https://github.com/OHDSI/WhiteRabbit"
                ]
            ],
            "description": "URL endpoint to where can we find this tool or resource",
            "type": "string",
            "format": "uri"
        },
        "authorsOntheGateway": {
            "$id": "#/properties/authorsOntheGateway",
            "title": "Paper Authors on the Gateway",
            "$comment": "",
            "examples": [
                [
                "Shahriar Kabir Khan", "Ned Stark"
            ]
        ],
            "description": "", 
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
            },
            "uniqueItems": true,
            "minItems": 1
                
            
        },
        "journal": {
            "$id": "#/properties/journal",
            "title": "Paper journal",
            "$comment": "",
            "examples": [],
            "description": "Journal Name and Year",
            "type": "array",
            "items": {
            "properties": {
                "journal": {
                    "$id": "#/properties/journal/journal",
                    "title": "Paper journal",
                    "$comment": "",
                    "examples": [
                        "Translational Biomedicine"
                    ],
                    "description": "Please provide name of journal",
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 80
                }
                }
            },
            "minItems": 1
        }
    },
        "journalYear": {
            "$id": "#/properties/journalYear",
            "title": "Paper Publication Year",
            "$comment": "",
            "examples": ["2020"],
            "description": "Please provide the paper publication year",
            "type": "int"
            
        }
    },
        "abstract": {
            "$id": "#/properties/abstract",
            "title": "Paper Abstract",
            "$comment": "",
            "examples": [
                "WhiteRabbit is a small application that can be used to analyze the structure and contents of a database as preparation for designing an ETL. It comes with RabbitInAHat, an application for interactive design of an ETL to the OMOP Common Data Model with the help of the scan report generated by White Rabbit."
            ],
            "description": "Please provide a brief summary of the paper.",
            "type": "string",
            "minLength": 2,
            "maxLength": 3000
        },
        "resultsInsights": {
            "$id": "#/properties/resultsInsights",
            "title": "Paper Results/Insights",
            "$comment": "",
            "examples": ["The main goal for CogStack is to provide a generalised way to access the various modes of unstructured data in a clinical record, harmonise them into a common format and index them in Elasticsearch for information retrieval. Ontop Elasticsearch is an NLP pipeline (CogStack MedCat) for information extraction."],
            "description": "Please provide any results or insights about the paper.",
            "type": "string",
            "minLength": 2,
            "maxLength": 3000
        },
        "keywords": {
            "$id": "#/properties/keywords",
            "title": "Paper Keywords",
            "$comment": "",
            "examples": [
                "Data Profiling",
                "Analysis",
                "Statistics"
            ],
            "description": "",
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
            },
            "uniqueItems": true,
            "minItems": 1
                    
            }
            
        },
        "domain": {
            "$id": "#/properties/domain",
            "title": "Paper Domain",
            "$comment": "",
            "examples": [
                "COVID-19",
                "Clinical Trial",
                "Respiratory"
            ],
            "description": "",
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
            },
            "uniqueItems": true
        },
        "relatedObjects": {
            "$id": "#/properties/relatedObjects",
            "title": "",
            "$comment": "",
            "examples": ["The relationships to papers, projects, datasets and tools."],
            "description": "",
            "type": "array",
            "items": {
                "properties": {
                    "resource": {
                        "$id": "#/properties/relatedObjects/resource",
                        "title": "Paper Related Resource",
                        "$comment": "",
                        "examples": [
                            "https://web.www.healthdatagateway.org/dataset/f93aea28-7592-42c0-a5e7-5802f0d6051f"
                        ],
                        "description": "The identifier of the related resource.",
                        "type": "string",
                        "format": "uri"
                    },
                    "relationship": {
                        "$id": "#/properties/relatedObjects/relationship",
                        "title": "Paper Relationship Between Resources",
                        "$comment": "",
                        "examples": [
                            "Covid-19 questionnaire data will be available in this dataset"
                        ],
                        "description": "What is the relationship between these resources?",
                        "type": "string",
                        "minLength": 2,
                        "maxLength": 3000
                    }
                }
            },
            "minItems": 1
    }
}
